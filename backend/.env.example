# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_at_least_32_characters_long
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_at_least_32_characters_long

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PATH=./data/luki.db

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Use your Expo app's URL or '*' for dev
CORS_ORIGIN=*

# ─── SMTP (welcome emails) ────────────────────────────────────────────────────
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@tu-dominio.com
SMTP_PASS=tu-smtp-password
EMAIL_FROM_NAME=Luki App
EMAIL_FROM_ADDRESS=noreply@tu-dominio.com
