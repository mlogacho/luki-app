EXPO_PUBLIC_API_URL=https://api.tu-backend.com
EXPO_PUBLIC_APP_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-SIDE only — set in backend/.env (never in the client app).
# These variables enable the welcome-email feature: when an admin creates a
# user, the backend sends an email with the temporary credentials.
# ─────────────────────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.tu-proveedor.com
# SMTP_PORT=587
# SMTP_USER=noreply@tu-dominio.com
# SMTP_PASS=tu-smtp-password
# EMAIL_FROM_NAME=Luki App
# EMAIL_FROM_ADDRESS=noreply@tu-dominio.com

